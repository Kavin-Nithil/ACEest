    {
      "name": "👤 Member Management",
      "item": [
        {
          "name": "POST /members — Add new member (Fat Loss)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Arjun Sharma\",\n  \"age\": 28,\n  \"program\": \"FL\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/members",
              "host": ["{{base_url}}"],
              "path": ["members"]
            },
            "description": "Registers a new gym member. Returns the member record with auto-assigned ID.\nThe test script below saves the member ID to {{member_id}} for use in the GET request."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "CREATED",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"message\": \"Member added successfully\",\n  \"member\": {\n    \"id\": 1,\n    \"name\": \"Arjun Sharma\",\n    \"age\": 28,\n    \"program\": \"FL\",\n    \"status\": \"active\"\n  }\n}"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Member has ID', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.member.id).to.be.a('number');",
                  "  pm.expect(json.member.status).to.eql('active');",
                  "  // Save ID for next request",
                  "  pm.collectionVariables.set('member_id', json.member.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },

        {
          "name": "POST /members — Add member (Muscle Gain)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Priya Nair\",\n  \"age\": 24,\n  \"program\": \"MG\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/members",
              "host": ["{{base_url}}"],
              "path": ["members"]
            }
          },
          "response": []
        },

        {
          "name": "GET /members/:id — Retrieve member",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/members/{{member_id}}",
              "host": ["{{base_url}}"],
              "path": ["members", "{{member_id}}"]
            },
            "description": "Retrieves a member by ID. Uses {{member_id}} variable set automatically by the POST /members test script."
          },
          "response": [
            {
              "name": "200 OK — Member found",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"member\": {\n    \"id\": 1,\n    \"name\": \"Arjun Sharma\",\n    \"age\": 28,\n    \"program\": \"FL\",\n    \"status\": \"active\"\n  }\n}"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Member data correct', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.member).to.have.property('name');",
                  "  pm.expect(json.member).to.have.property('program');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },

