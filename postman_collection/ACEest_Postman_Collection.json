              "mode": "raw",
              "raw": "{\n  \"weight_kg\": 70\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/bmi",
              "host": ["{{base_url}}"],
              "path": ["bmi"]
            },
            "description": "height_cm is missing — should return 400 Bad Request."
          },
          "response": [
            {
              "name": "400 Bad Request",
              "status": "BAD REQUEST",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Missing field: 'height_cm'\"\n}"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 400', () => pm.response.to.have.status(400));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },

        {
          "name": "POST /bmi — ❌ Zero height (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"weight_kg\": 70,\n  \"height_cm\": 0\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/bmi",
              "host": ["{{base_url}}"],
              "path": ["bmi"]
            },
            "description": "height_cm = 0 is invalid — division by zero protection."
          },
          "response": []
        }
      ]
    },

    {
      "name": "🔥 Calorie Calculator (TDEE)",
      "item": [
        {
          "name": "POST /calories — Male, Moderate activity",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"weight_kg\": 75,\n  \"height_cm\": 178,\n  \"age\": 28,\n  \"gender\": \"male\",\n  \"activity\": \"moderate\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/calories",
              "host": ["{{base_url}}"],
              "path": ["calories"]
            },
            "description": "Calculates Total Daily Energy Expenditure (TDEE) using the Mifflin-St Jeor equation.\n\nActivity levels:\n- sedentary (×1.2)\n- light (×1.375)\n- moderate (×1.55)\n- active (×1.725)\n- very_active (×1.9)"
          },
          "response": [
            {
              "name": "200 OK — TDEE calculated",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"tdee_kcal\": 2798,\n  \"input\": {\n    \"weight_kg\": \"75\",\n    \"height_cm\": \"178\",\n    \"age\": \"28\",\n    \"gender\": \"male\",\n    \"activity\": \"moderate\"\n  }\n}"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('tdee_kcal is integer', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.tdee_kcal).to.be.a('number');",
                  "  pm.expect(Number.isInteger(json.tdee_kcal)).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },

